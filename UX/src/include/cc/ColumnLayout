#pragma once

#include <cc/View>

namespace cc {

/** \class ColumnLayout cc/ColumnLayout
  * \ingroup ui_layout
  * \brief %Layout children views in a column
  */
class ColumnLayout final: public View::Layout
{
public:
    /** Create new column layout
      */
    ColumnLayout();

    ColumnAlign align() const; ///< Get column alignment
    ColumnLayout &align(ColumnAlign newValue); ///< %Set column alignment

    double indent() const; ///< Get horizontal indentation
    ColumnLayout &indent(double newValue); ///< %Set horizontal indentation

private:
    friend class Object;

    struct State final: public View::Layout::State
    {
        State() = default;

        Orientation orientation() const override { return Orientation::Vertical; }

        void updateLayout();

        Property<ColumnAlign> align { ColumnAlign::Left };
        Property<double> indent { 0 };

        Property<void> update { [this]{ updateLayout(); } };
        bool firstTime_ { true };
        bool setViewSize_ { false };
    };

    State& me();
    const State& me() const;
};

} // namespace cc
