#pragma once

#include <cc/View>

namespace cc {

/** \class RowLayout cc/RowLayout
  * \ingroup ui_layout
  * \brief %Layout children views in a row
  * \see RowLayout
  */
class RowLayout final: public View::Layout
{
public:
    /** Create new column layout
      */
    RowLayout();

    RowAlign align() const; ///< Get row alignment
    RowLayout &align(RowAlign newValue); ///< %Set row alignment

private:
    friend class Object;

    struct State final: public View::Layout::State
    {
        State() = default;

        Orientation orientation() const override { return Orientation::Horizontal; }

        void updateLayout();

        Property<RowAlign> align { RowAlign::Top };

        Property<void> update { [this]{ updateLayout(); } };
        bool firstTime_ { true };
        bool setViewSize_ { false };
    };

    State& me();
    const State& me() const;
};

} // namespace cc
