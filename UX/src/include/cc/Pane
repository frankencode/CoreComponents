#pragma once

#include <cc/View>

namespace cc {

/** \class Pane cc/Pane
  * \ingroup ui
  * \brief A view contained in another view, e.g. inside a Flickable
  */
class Pane: public View
{
public:
    /** Create a pane
      */
    explicit Pane(Out<Pane> self = None{}):
        View{onDemand<State>}
    {
        View::associate<Pane>(self);
    }

    /** Create a pane of \a size
      */
    explicit Pane(Size size, Out<Pane> self = None{}):
        View{new State}
    {
        View::size(size);
        View::associate<Pane>(self);
    }

    /** Create a pane of size (\a width, \a height)
      */
    Pane(double width, double height, Out<Pane> self = None{}):
        Pane{Size{width, height}, self}
    {}

    /** Create a pane organizing its children with \a layout
      */
    explicit Pane(const Layout &layout, Out<Pane> self = None{}):
        View{new State}
    {
        View::layout(layout);
        View::associate<Pane>(self);
    }

    /** Get a weak reference in \a self
      */
    Pane &associate(Out<Pane> self);

protected:
    friend class Object;

    /** \brief Internal state
      * \hideinheritancegraph
      */
    struct State: public View::State
    {
        State() = default;

        Size preferredSize() const override;
    };
};

} // namespace cc
