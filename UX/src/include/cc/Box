#pragma once

#include <cc/View>

namespace cc {

/** \class Box cc/Box
  * \ingroup ui
  * \brief Filled rectangle with rounded corners
  */
class Box final: public View
{
public:
    /** Create a box
      */
    explicit Box(Out<Box> self = None{});

    /** Create a box of \a size
      */
    explicit Box(const Size &size, Out<Box> self = None{});

    /** Create a box of size (\a width, \a height)
      */
    Box(double width, double height, Out<Box> self = None{}):
        Box{Size{width, height}, self}
    {}

    /** Get a weak reference in \a self
      */
    Box &associate(Out<Box> self);

    CC_PROPERTY(Box, double, radius)
    CC_PROPERTY(Box, Color, color)
    CC_PROPERTY(Box, Pen, border)

protected:
    /** \brief Internal state
      * \hideinheritancegraph
      */
    struct State: public View::State
    {
        State();

        bool isPainted() const override { return (color().isValid() || !border().isNull()) && width() > 0 && height() > 0; }
        // bool isOpaque() const override { return color().isValid() && color().isOpaque() && radius() == 0; }

        Property<double> radius;
        Property<Color> color;
        Property<Pen> border;
    };

    explicit Box(State *newState):
        View{newState}
    {}

    State &me() { return View::me().as<State>(); }
    const State &me() const { return View::me().as<State>(); }
};

} // namespace cc
