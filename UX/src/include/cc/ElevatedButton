#pragma once

#include <cc/PushButton>

namespace cc {

/** \class ElevatedButton cc/ElevatedButton
  * \ingroup ui_buttons
  * \brief Elevated button
  */
class ElevatedButton final: public PushButton
{
public:
    /** Create an elevated button
      */
    explicit ElevatedButton(Out<ElevatedButton> self = None{});

    /** Create an elevated button
      */
    explicit ElevatedButton(const Picture &icon, Out<ElevatedButton> self = None{});

    /** Create an elevated button with a text label
      */
    explicit ElevatedButton(const String &text, Out<ElevatedButton> self = None{});

    /** Create an elevated button with a text label and icon
      */
    ElevatedButton(const String &text, const Picture &icon, Out<ElevatedButton> self = None{});

    /** Get a weak reference in \a self
      */
    ElevatedButton &associate(Out<ElevatedButton> self);

private:
    struct State;
};

} // namespace cc
