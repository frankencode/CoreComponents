#pragma once

#include <cc/TouchButton>

namespace cc {

/** \class FilledButton cc/FilledButton
  * \ingroup ui_buttons
  * \brief Filled button
  */
class FilledButton final: public TouchButton
{
public:
    /** Create a filled button
      */
    explicit FilledButton(Out<FilledButton> self = None{});

    /** Create a filled button with \a text
      */
    explicit FilledButton(const String &text, Out<FilledButton> self = None{});

    /** Create a filled button with \a text and \a icon
      */
    FilledButton(const String &text, const Picture &icon, Out<FilledButton> self = None{});

    /** Get a weak reference in \a self
      */
    FilledButton &associate(Out<FilledButton> self);

private:
    struct State;
};

} // namespace cc
