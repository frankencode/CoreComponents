#pragma once

#include <cc/TouchButton>

namespace cc {

/** \class OutlineButton cc/OutlineButton
  * \ingroup ui_buttons
  * \brief %Outlined button
  */
class OutlineButton final: public TouchButton
{
public:
    /** Create a outline button
      */
    explicit OutlineButton(Out<OutlineButton> self = None{});

    /** Create a outline button with text label
      */
    explicit OutlineButton(const String &text, Out<OutlineButton> self = None{});

    /** Create a outline button with text label and an icon
      */
    OutlineButton(const String &text, const Picture &icon, Out<OutlineButton> self = None{});

    /** Get a weak reference in \a self
      */
    OutlineButton &associate(Out<OutlineButton> self);

private:
    struct State;
};

} // namespace cc
