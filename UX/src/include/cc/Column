#include <cc/View>
#include <cc/ColumnLayout>

namespace cc {

/** \class Column cc/Column
  * \brief A view that arranges its children in a column
  * \ingroup ui
  */
class Column final: public View
{
public:
    /** Create a new column
      */
    explicit Column(Out<Column> self = None{}):
        View{ColumnLayout{}}
    {
        View::associate<Column>(self);
    }

    /** Create a new column of size (\a width, \a height)
      */
    Column(double width, double height, Out<Column> self = None{}):
        Column{Size{width, height}, self}
    {}

    /** Create a new column of \a size
      */
    explicit Column(const Size &size, Out<Column> self = None{}):
        View{ColumnLayout{}}
    {
        View::associate<Column>(self);
        View::size(size);
    }

    ColumnAlign align() const { return layout().align(); } ///< Get column alignment
    Column &align(ColumnAlign newValue) { layout().align(newValue); return *this; } ///< %Set column alignment

    double indent() const { return layout().indent(); } ///< Get horizontal indentation
    Column &indent(double newValue) { layout().indent(newValue); return *this; } ///< %Set horizontal indentation

    Size margin() const { return View::layout().margin(); } ///< Get inner layout margins
    Column &margin(Size newValue) { View::layout().margin(newValue); return *this; } ///< %Set inner layout margins

    double spacing() const { return View::layout().spacing(); } ///< Get layout spacing
    Column &spacing(double newValue) { View::layout().spacing(newValue); return *this; } ///< %Set layout spacing

private:
    ColumnLayout layout() const
    {
        return View::layout().as<ColumnLayout>();
    }
};

} // namespace cc
