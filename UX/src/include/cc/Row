#include <cc/View>
#include <cc/RowLayout>

namespace cc {

/** \class Row cc/Row
  * \brief A view that arranges its children in a row
  * \ingroup ui
  */
class Row final: public View
{
public:
    /** Create a row
      */
    explicit Row(Out<Row> self = None{}):
        View{RowLayout{}}
    {
        View::associate<Row>(self);
    }

    /** Create a row of \a size
      */
    explicit Row(const Size &size, Out<Row> self = None{}):
        View{RowLayout{}}
    {
        View::associate<Row>(self);
        View::size(size);
    }

    /** Create a row of size (\a width, \a height)
      */
    Row(double width, double height, Out<Row> self = None{}):
        Row{Size{width, height}, self}
    {}

    RowAlign align() const { return layout().align(); } ///< Get row alignment
    Row &align(RowAlign newValue) { layout().align(newValue); return *this; } ///< %Set row alignment

    Size margin() const { return View::layout().margin(); } ///< Get inner layout margins
    Row &margin(Size newValue) { View::layout().margin(newValue); return *this; } ///< %Set inner layout margins

    double spacing() const { return View::layout().spacing(); } ///< Get layout spacing
    Row &spacing(double newValue) { View::layout().spacing(newValue); return *this; } ///< %Set layout spacing

private:
    RowLayout layout() const
    {
        return View::layout().as<RowLayout>();
    }
};

} // namespace cc
