#pragma once

#include <cc/PushButton>

namespace cc {

/** \class FloatingButton cc/FloatingButton
  * \ingroup ui_buttons
  * \brief Floating button
  */
class FloatingButton final: public PushButton
{
public:
    /** Create a floating button
      */
    explicit FloatingButton(Out<FloatingButton> self = None{});

    /** Create a floating button with an icon
      */
    explicit FloatingButton(const Picture &icon, Out<FloatingButton> self = None{});

    /** Create a floating button with a text label and an icon
      */
    explicit FloatingButton(const String &text, Out<FloatingButton> self = None{});

    /** Create a floating button with a text label and an icon
      */
    FloatingButton(const String &text, const Picture &icon, Out<FloatingButton> self = None{});

    /** Get a weak reference in \a self
      */
    FloatingButton &associate(Out<FloatingButton> self);

private:
    struct State;
};

} // namespace cc
