#pragma once

#include <cc/View>

namespace cc {

/** \class PlainText cc/PlainText
  * \ingroup ui
  * \brief Plain text display
  * \see TextView
  *
  * A PlainText shows a single span of text.
  * When maxWidth() is set the text will be automatically wrapped if necessary onto multiple lines.
  */
class PlainText final: public View
{
public:
    /** Create a plain text display
      */
    explicit PlainText(Out<PlainText> self = None{});

    /** Create a plain text display
      * \param text Initial text
      */
    explicit PlainText(const String &text, Out<PlainText> self = None{});

    /** Create a plain text display
      * \param text Initial text
      * \param font Initial font
      */
    PlainText(const String &text, Font font, Out<PlainText> self = None{});

    /** Get a weak reference in \a self
      */
    PlainText &associate(Out<PlainText> self);

    String text() const; ///< Get text
    PlainText &text(const String &newValue); ///< %Set text
    PlainText &text(Definition<String> &&f); ///< Define text

    Font font() const; ///< Get font
    PlainText &font(Font newValue); ///< %Set font
    PlainText &font(Definition<Font> &&f); ///< Define font

    Color color() const; ///< Get text color
    PlainText &color(Color newValue); ///< %Set text color
    PlainText &color(Definition<Color> &&f); ///< Define text color

    Size margin() const; ///< Get inside margins
    PlainText &margin(Size newValue); ///< %Set inside margins
    PlainText &margin(Definition<Size> &&f); ///< Define inside margins

    double maxWidth() const; ///< Get maximum width
    PlainText &maxWidth(double newValue); ///< %Set maximum width
    PlainText &maxWidth(Definition<double> &&f); ///< Define maximum width

    using GetColor = Function<Color(int)>; ///< Get color for a given byte offset

    PlainText &getInk(GetColor &&f); ///< %Set function to colorize the foreground
    PlainText &getPaper(GetColor &&f); ///< %Set function to colorize the background

private:
    struct State;

    explicit PlainText(State *newState);
    explicit PlainText(CreateState onDemand);

    State &me();
    const State &me() const;
};

} // namespace cc
