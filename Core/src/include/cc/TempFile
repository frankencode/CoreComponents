#pragma once

#include <cc/File>

namespace cc {

/** \class TempFile cc/TempFile
  * \ingroup file_system
  * \brief Temporary files
  */
class TempFile final: public File
{
public:
    /** Open a new temporary file
      */
    TempFile():
        File{File::createTemp(), FileOpen::ReadWrite|FileOpen::Temporary}
    {}
};

} // namespace cc
