#pragma once

namespace cc {

/** \class NullFormat cc/NullFormat
  * \brief Discarding formatted output sink
  */
class NullFormat {
public:
    /// Drop output
    template<class T>
    inline const NullFormat &operator<<(const T &) const { return *this; }
};

} // namespace cc
