#pragma once

#include <cc/can_open/sdo/BlockRequest>

namespace cc::can_open::sdo {

class BlockReadStartRequest final: public BlockRequest
{
public:
    static constexpr const char *typeName() { return "can_open.sdo.block_read_start_request"; }

    static CanFrame createFrame(int serverId);

    explicit BlockReadStartRequest(const CanFrame &frame):
        BlockRequest{frame}
    {}

    explicit operator bool() const { return isValid(); }

    bool isValid() const
    {
        return
            BlockRequest::isValid() &&
            BlockRequest::specifier() == BlockRequest::Specifier::BlockReadStart;
    }

    String toString() const;
};

} // namespace cc::can_open::sdo
